# Helius API Key (Required)
# Get your free API key from https://helius.dev
HELIUS_API_KEY=your_helius_api_key_here

# Shyft API Key (Optional — fallback RPC provider for Helius outages)
# Get a free key from https://shyft.to
# If not set, system runs Helius-only and logs a warning at startup
SHYFT_API_KEY=

# Solana RPC Endpoint (Optional)
# Default: https://api.mainnet-beta.solana.com
SOLANA_RPC=https://api.mainnet-beta.solana.com

# Output Directory (Optional)
# Default: ./exports
OUTPUT_DIR=./exports

# Cache Directory (Optional)
# Default: ./data/cache
CACHE_DIR=./data/cache

# Log Level (Optional)
# Options: debug, info, warn, error
# Default: info
LOG_LEVEL=info

# Database
DATABASE_URL=./data/echo.db
INACTIVITY_DAYS=30

# Telegram Bot Token (Optional)
TELEGRAM_BOT_TOKEN=your_token_here
TELEGRAM_CHAT_ID=pending
ALERT_SIGNAL_THRESHOLD=50